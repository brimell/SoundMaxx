# Copy this file to .env and adjust values for your release workflow.
# .env is gitignored to keep tokens local.

# Repository slug (required if autodetect fails)
GITHUB_REPOSITORY=brimell/SoundMax

# GitHub authentication (optional if you already ran `gh auth login`)
# GH_TOKEN=ghp_xxx
# GITHUB_TOKEN=ghp_xxx

# Release metadata
# RELEASE_TAG=v1.0.0
# RELEASE_TITLE=SoundMaxx v1.0.0
# RELEASE_NOTES=Automated release notes here.

# Optional: read release notes from a file instead of inline text
# RELEASE_NOTES_FILE=release-notes/v1.0.0.md

# Asset path override (defaults to build/SoundMaxx-Installer.dmg)
# ASSET_PATH=build/SoundMaxx-Installer.dmg
# RELEASE_ASSET_PATH=build/SoundMaxx-Installer.dmg

# Workflow defaults (true/false, yes/no, 1/0)
# RELEASE_SKIP_BUILD=false
# RELEASE_PRERELEASE=false

# Optional: default env file path (if not using ./.env)
# PUBLISH_ENV_FILE=.env
